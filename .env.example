# Copy this file to .env and fill in your values.
# The app works fully in rules-only mode without any keys.

# ── LLM layer (optional) ────────────────────────────────────────────────────
# When set, the Express server at http://localhost:3001 will call the Anthropic
# API and return a second-opinion classification.  Confidence is then computed
# from agreement (High) or disagreement (Low) between the rules and the LLM.
# Without this key the server still runs but responds { available: false }, and
# the frontend falls back to rules-derived confidence.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model to use for classification (defaults to claude-sonnet-4-6 if not set)
MODEL=claude-sonnet-4-6

# Port for the Express API server (defaults to 3001)
# API_PORT=3001
